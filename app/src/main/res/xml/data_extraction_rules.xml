<?xml version="1.0" encoding="utf-8"?>
<!-- No app data is backed up: tokens live in EncryptedSharedPreferences and must
     not leave the device via cloud/device-transfer backups (§3.2, §9). -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
