    <path
        android:fillColor="#0072FF"
        android:pathData="M34,30 H46 V78 H34 Z" />
    <!-- Bowl -->
    <path
        android:fillColor="#0072FF"
        android:pathData="M44,30 H60 a15,15 0 0 1 0,30 H44 Z" />
